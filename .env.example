# ---- Site ----
PUBLIC_SITE_URL=https://thehydrationcode.com

# ---- Affiliate tracking IDs ----
# Amazon Associates store ID, e.g. hydrationcode-20
# Leave blank until the Associates account exists. Links will still build.
AMAZON_ASSOCIATE_TAG=

# ShareASale affiliate ID
SHAREASALE_ID=

# Impact Radius publisher ID
IMPACT_ID=

# ---- Analytics ----
# Plausible: the domain as registered in the Plausible dashboard
PUBLIC_PLAUSIBLE_DOMAIN=thehydrationcode.com

# ---- Newsletter ----
# Kit (ConvertKit) form submit endpoint, or any POST endpoint accepting { email }
PUBLIC_NEWSLETTER_ENDPOINT=

# ---- Keystatic (Phase 6) ----
# Unset (or 'local') for filesystem editing during dev. 'github' for browser
# editing against the deployed site — requires a GitHub App; see docs/CMS.md.
KEYSTATIC_STORAGE=
KEYSTATIC_GITHUB_OWNER=
KEYSTATIC_GITHUB_REPO=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
