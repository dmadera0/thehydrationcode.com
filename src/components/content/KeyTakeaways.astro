---
interface Props {
  title?: string;
}

const { title = 'Key takeaways' } = Astro.props;
---

<aside class="key-takeaways" aria-label={title}>
  <p class="kt-label source-label">{title}</p>
  <div class="kt-body">
    <slot />
  </div>
</aside>

<style>
  .key-takeaways {
    margin-block: 2rem;
    padding: 1.5rem 1.75rem;
    border-radius: var(--radius-panel);
    border: 1px solid var(--color-line);
  }

  .kt-label {
    color: var(--color-brand);
    margin-block-end: 0.75rem;
  }

  .kt-body :global(ul) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-inline-start: 1.25rem;
  }

  .kt-body :global(li) {
    list-style: disc;
  }

  .kt-body :global(p:last-child) {
    margin-block-end: 0;
  }
</style>
