---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import AffiliateLink from './AffiliateLink.astro';
import PriceSlot from './PriceSlot.astro';
import { resolvePrice } from '@lib/pricing';

interface Props {
  bottle: CollectionEntry<'bottles'>;
}

const { bottle } = Astro.props;
const { name, brand, tagline, bestFor, editorsChoice, features, image, imageAlt, rating, affiliateId } =
  bottle.data;

const price = resolvePrice(bottle.data);
const ratingPct = `${(rating / 5) * 100}%`;
---

<article class="product-card">
  {editorsChoice && <p class="ribbon">Editor's Choice</p>}

  <a href={`/best-bottles/${bottle.id}`} class="image-link">
    <Image src={image} alt={imageAlt} width={400} height={400} class="product-image" />
  </a>

  <div class="card-body">
    <div class="eyebrow-row">
      <p class="brand source-label">{brand}</p>
      <div class="stars" style={`--pct: ${ratingPct}`} aria-label={`${rating} out of 5 stars`}>
        <span class="stars-bg" aria-hidden="true">★★★★★</span>
        <span class="stars-fg" aria-hidden="true">★★★★★</span>
        <span class="rating-value">{rating.toFixed(1)}</span>
      </div>
    </div>

    <h3 class="name"><a href={`/best-bottles/${bottle.id}`}>{name}</a></h3>
    <p class="tagline">{tagline}</p>
    <p class="best-for-pill">{bestFor}</p>

    <ul class="features">
      {features.map((feature) => (
        <li>
          <span class="check" aria-hidden="true">✓</span>
          {feature}
        </li>
      ))}
    </ul>

    <div class="footer-row">
      <PriceSlot bottle={bottle} />
      <AffiliateLink affiliateId={affiliateId} class="product-cta">{price.cta} ↗</AffiliateLink>
    </div>
  </div>
</article>

<style>
  .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-panel);
    overflow: hidden;
  }

  .ribbon {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-card);
    background-color: var(--color-brand);
    color: var(--color-surface);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .image-link {
    display: block;
  }

  .product-image {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
  }

  .eyebrow-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .brand {
    color: var(--color-brand);
  }

  .stars {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
  }

  .stars-bg,
  .stars-fg {
    letter-spacing: 0.05em;
  }

  .stars-bg {
    color: var(--color-line);
  }

  .stars-fg {
    position: absolute;
    inset-inline-start: 0;
    top: 0;
    overflow: hidden;
    width: var(--pct);
    color: var(--color-brand);
    white-space: nowrap;
  }

  .rating-value {
    font-size: 0.8125rem;
    color: var(--color-body);
  }

  .name a {
    font-size: var(--text-card);
    line-height: var(--text-card--line-height);
    letter-spacing: var(--text-card--letter-spacing);
    color: var(--color-ink);
    text-decoration: none;
  }

  .tagline {
    font-size: 0.9375rem;
  }

  .best-for-pill {
    align-self: flex-start;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-card);
    background-color: var(--color-brand-tint);
    color: var(--color-brand);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .features {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-block: 0.25rem;
  }

  .features li {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-body);
  }

  .check {
    color: var(--color-brand);
    font-weight: 700;
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-block-start: 0.5rem;
  }

  /* :global() is required here, not just belt-and-suspenders: the actual
     <a> lives inside AffiliateLink.astro, one component over, so Astro's
     normal per-file style scoping can't reach it — only the class name
     passed as a prop can. Named .product-cta (not .cta) precisely so this
     global rule can't collide with Header's own scoped .cta button. */
  :global(.product-cta) {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-card);
    background-color: var(--color-brand);
    color: var(--color-surface);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  :global(.product-cta:hover) {
    background-color: var(--color-brand-dark);
  }
</style>
