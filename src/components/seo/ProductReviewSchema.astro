---
/**
 * Product schema for bottle detail pages — deliberately Review, not
 * AggregateRating.
 *
 * AggregateRating represents an aggregation of independent ratings (user
 * reviews, survey responses). Our rating is a single editorial score this
 * site assigns — there's no population of reviewers behind it. Emitting
 * AggregateRating for that would misrepresent its provenance to Google and
 * is exactly the kind of structured-data mismatch that draws a manual
 * action. Review lets us attribute the score honestly to our own
 * Organization as the reviewing entity, which is what it actually is.
 */
import type { CollectionEntry } from 'astro:content';
import JsonLd from './JsonLd.astro';
import { SITE } from '@data/site';

interface Props {
  bottle: CollectionEntry<'bottles'>;
  url: string;
  /** The page's own "Our verdict" text — one copy, shared with Review.reviewBody. */
  reviewBody: string;
}

const { bottle, url, reviewBody } = Astro.props;
const { name, brand, tagline, image, rating, reviewedAt, pros, cons } = bottle.data;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  brand: { '@type': 'Brand', name: brand },
  description: tagline,
  image: new URL(image.src, SITE.url).toString(),
  url,
  review: {
    '@type': 'Review',
    reviewBody,
    datePublished: reviewedAt.toISOString(),
    reviewRating: {
      '@type': 'Rating',
      ratingValue: rating,
      bestRating: 5,
      worstRating: 1,
    },
    author: {
      '@type': 'Organization',
      name: SITE.name,
    },
    // Google's pros/cons rich result properties — ProsCons.astro already
    // holds this exact data, so this just mirrors it into structured data.
    positiveNotes: {
      '@type': 'ItemList',
      itemListElement: pros.map((text, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: text,
      })),
    },
    negativeNotes: {
      '@type': 'ItemList',
      itemListElement: cons.map((text, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: text,
      })),
    },
  },
};
---

<JsonLd schema={schema} />
