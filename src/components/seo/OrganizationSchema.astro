---
/** Sitewide Organization schema — rendered once, in BaseLayout. */
import JsonLd from './JsonLd.astro';
import { SITE } from '@data/site';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  // TODO: swap for a real raster logo (PNG/WebP, min 112x112) before launch —
  // an SVG mark is fine for the favicon but isn't reliably read by every
  // consumer of Organization.logo.
  logo: `${SITE.url}/favicon.svg`,
  description: SITE.description,
};
---

<JsonLd schema={schema} />
