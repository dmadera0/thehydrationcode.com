---
import type { CollectionEntry } from 'astro:content';
import { getEntries } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import SourceList from '@components/content/SourceList.astro';
import ArticleCard from '@components/content/ArticleCard.astro';
import ArticleSchema from '@components/seo/ArticleSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { PILLAR_LABELS } from '@data/taxonomy';
import { SITE } from '@data/site';
import { getReadingMinutes } from '@lib/reading-time';
import { getPublishedPosts } from '@lib/posts';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, dek, pillar, publishedAt, updatedAt, heroImage, heroAlt, sources, faq, relatedBottles } =
  post.data;

const readingMinutes = getReadingMinutes(post.body ?? '');
const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
const relatedBottleEntries = relatedBottles?.length ? await getEntries(relatedBottles) : [];

const relatedPosts = (await getPublishedPosts())
  .filter((p) => p.data.pillar === pillar && p.id !== post.id)
  .slice(0, 3);

const canonicalUrl = new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = `/og/posts/${post.id}.png`;
const breadcrumbItems = [
  { name: 'Home', url: SITE.url },
  { name: 'The Research', url: `${SITE.url}/research` },
  { name: PILLAR_LABELS[pillar], url: `${SITE.url}/research/${pillar}` },
  { name: title, url: canonicalUrl },
];
---

<BaseLayout title={title} description={dek} ogImage={ogImage}>
  <ArticleSchema post={post} url={canonicalUrl} />
  <BreadcrumbSchema items={breadcrumbItems} />
  {faq && faq.length > 0 && <FAQSchema faq={faq} />}

  <article class="article">
    <header class="article-head">
      <p class="pillar-badge source-label">{PILLAR_LABELS[pillar]}</p>
      <h1>{title}</h1>
      <p class="dek">{dek}</p>
      <div class="meta">
        <span>Published {dateFormatter.format(publishedAt)}</span>
        {updatedAt && <span>Updated {dateFormatter.format(updatedAt)}</span>}
        <span>{readingMinutes} min read</span>
      </div>
      <Image src={heroImage} alt={heroAlt} width={1200} height={675} class="hero-image" />
    </header>

    <div class="prose">
      <slot />
    </div>

    <SourceList sources={sources} />

    {faq && faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">Frequently asked questions</h2>
        <dl>
          {faq.map((item) => (
            <div class="faq-item">
              <dt>{item.q}</dt>
              <dd>{item.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {relatedBottleEntries.length > 0 && (
      <section class="related-bottles" aria-labelledby="related-bottles-heading">
        <h2 id="related-bottles-heading">Bottles mentioned in this article</h2>
        <ul>
          {relatedBottleEntries.map((bottle) => (
            <li>
              <a href={`/best-bottles/${bottle.id}`}>
                <span class="bottle-name">{bottle.data.name}</span>
                <span class="bottle-tagline">{bottle.data.tagline}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="related-posts" aria-labelledby="related-posts-heading">
        <h2 id="related-posts-heading">More on {PILLAR_LABELS[pillar]}</h2>
        <div class="related-posts-grid">
          {relatedPosts.map((relatedPost) => <ArticleCard post={relatedPost} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .article {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding: 3rem var(--spacing-gutter) 4rem;
  }

  .article-head {
    margin-block-end: 2.5rem;
  }

  .pillar-badge {
    display: inline-block;
    margin-block-end: 1rem;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-card);
    background-color: var(--color-brand-tint);
    color: var(--color-brand);
  }

  .article-head h1 {
    font-size: var(--text-section);
    line-height: var(--text-section--line-height);
    letter-spacing: var(--text-section--letter-spacing);
  }

  .dek {
    margin-block-start: 0.75rem;
    font-size: 1.125rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 1rem;
    margin-block-start: 1rem;
    font-size: 0.875rem;
    color: var(--color-body);
  }

  .hero-image {
    margin-block-start: 1.75rem;
    width: 100%;
    height: auto;
    border-radius: var(--radius-panel);
  }

  .prose :global(h2) {
    font-size: var(--text-card);
    line-height: var(--text-card--line-height);
    margin-block: 2rem 1rem;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin-block: 1.75rem 0.75rem;
  }

  .prose :global(p) {
    margin-block-end: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-block-end: 1.25rem;
    padding-inline-start: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prose :global(li) {
    list-style: revert;
  }

  .prose :global(a) {
    color: var(--color-accent);
  }

  .prose :global(blockquote) {
    margin-block: 1.5rem;
    padding-inline-start: 1.25rem;
    border-inline-start: 3px solid var(--color-line);
    color: var(--color-body);
    font-style: italic;
  }

  .faq {
    margin-block-start: 3rem;
  }

  .faq h2,
  .related-bottles h2,
  .related-posts h2 {
    font-size: var(--text-card);
    line-height: var(--text-card--line-height);
    margin-block-end: 1.25rem;
  }

  .faq dl {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .faq dt {
    font-weight: 600;
    color: var(--color-ink);
    margin-block-end: 0.375rem;
  }

  .related-bottles {
    margin-block-start: 3rem;
  }

  .related-bottles ul {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-bottles a {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    text-decoration: none;
  }

  .bottle-name {
    font-weight: 600;
    color: var(--color-ink);
  }

  .bottle-tagline {
    font-size: 0.875rem;
    color: var(--color-body);
  }

  .related-posts {
    margin-block-start: 3rem;
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 1.5rem;
  }
</style>
